# EditorConfig — consistent style across editors. https://editorconfig.org
root = true

[*]
charset = utf-8
end_of_line = lf
insert_final_newline = true
trim_trailing_whitespace = true
indent_style = space

# Python — 4 spaces (PEP 8 / ruff).
[*.py]
indent_size = 4

# Web assets — 2 spaces (house style).
[*.{js,css,html}]
indent_size = 2

# JSON / YAML config.
[*.{json,yml,yaml}]
indent_size = 2

# Don't enforce rules on generated or vendored files.
[{staticfiles/**,**/migrations/**,theme/static_src/node_modules/**,static/css/dist/**}]
trim_trailing_whitespace = false
insert_final_newline = false
